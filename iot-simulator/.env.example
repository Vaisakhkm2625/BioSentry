# ──────────────────────────────────────────
# BioSentry IoT Simulator - Environment Config
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────

# Unique identifier for this IoT device
DEVICE_ID=biosentry-device-001

# Your Firebase Web API Key (Firebase Console → Project Settings → General)
FIREBASE_API_KEY=your-firebase-web-api-key

# Your Firebase Realtime Database URL
# (Firebase Console → Realtime Database → copy the URL shown at the top)
FIREBASE_DATABASE_URL=https://biosentry-3dabf-default-rtdb.firebaseio.com

# A dedicated Firebase Auth user for this IoT device
# Create one in: Firebase Console → Authentication → Users → Add user
IOT_USER_EMAIL=iot-sim@biosentry.com
IOT_USER_PASSWORD=your-iot-device-password

# The URL where your BioSentry PWA is running
# Used to build the pairing QR code link
PWA_URL=http://localhost:5173
